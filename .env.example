# Copie para .env e preencha

PORT=3000
JWT_SECRET=troque_por_uma_chave_muito_secreta_aqui_123

# Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.[SEU-ID].supabase.co:5432/postgres

# Gmail: Conta Google → Segurança → Senhas de app → gerar senha de 16 dígitos
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seuemail@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM="Licenças & Alvarás <seuemail@gmail.com>"

# Cron: todo dia às 08h (horário de Brasília)
CRON_SCHEDULE=0 8 * * *
